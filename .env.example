# Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB=semanticsearch

# Vector Database (Qdrant)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=local_shared_products

# AI/ML Services
GEMINI_API_KEY=your_gemini_api_key_here
EMBED_MODEL=gemini-embedding-001
EMBED_DIM=3072

# Authentication & Security
JWT_SECRET=change-this-in-production-use-a-strong-random-key
ALGORITHM=HS256

# Cache Configuration (Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Postgres (LangGraph checkpointer for multi-agent chat state)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=chatbot_state
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_CHECKPOINTER_ENABLED=false
MAX_CHAT_HISTORY_MESSAGES=8

# Multi-agent LLM defaults (can be overridden per-request via Magento module config)
CHAT_LLM_PROVIDER=google
CHAT_LLM_MODEL=gemini-2.0-flash-lite
INTENT_ROUTER_ENABLED=true

# WooCommerce Integration
WC_WEBHOOK_SECRET=mysecretkey123
WC_API_URL=https://your-store.com/wp-json/wc/v3
WC_CONSUMER_KEY=your_consumer_key
WC_CONSUMER_SECRET=your_consumer_secret

# Application Settings
DEBUG=false
LOG_LEVEL=INFO
ENVIRONMENT=production

# CORS Settings (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Monitoring & Analytics
SENTRY_DSN=
ENABLE_METRICS=true
